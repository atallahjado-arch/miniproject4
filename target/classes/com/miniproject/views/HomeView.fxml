<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.miniproject.controller.HomeController"
            style="-fx-background-color: #1a1a2e;">

    <!-- Top bar -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color: #16213e; -fx-padding: 16 24;">
            <Label text="Business Manager"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #e2e8f0;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Logout" onAction="#handleLogout"
                    style="-fx-background-color: transparent; -fx-text-fill: #94a3b8;
                           -fx-border-color: #334155; -fx-border-radius: 6;
                           -fx-background-radius: 6; -fx-padding: 6 14; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <!-- Center cards -->
    <center>
        <VBox alignment="CENTER" spacing="24">
            <padding><Insets top="60" right="60" bottom="60" left="60"/></padding>

            <Label text="Select a module to manage"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #e2e8f0;"/>
            <Label text="Each team member owns one business entity"
                   style="-fx-font-size: 13px; -fx-text-fill: #64748b;"/>

            <HBox spacing="24" alignment="CENTER">

                <!-- Clients Card -->
                <VBox alignment="CENTER" spacing="14" prefWidth="220"
                      style="-fx-background-color: #16213e; -fx-background-radius: 12;
                             -fx-border-color: #1e3a5f; -fx-border-radius: 12; -fx-padding: 32;">
                    <Label text="👤" style="-fx-font-size: 40px;"/>
                    <Label text="Clients" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #e2e8f0;"/>
                    <Label text="Manage client records" style="-fx-font-size: 12px; -fx-text-fill: #64748b;" wrapText="true"/>
                    <Button text="Open Clients" onAction="#goToClients" maxWidth="Infinity"
                            style="-fx-background-color: #4361ee; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-background-radius: 8;
                                   -fx-padding: 10 0; -fx-cursor: hand;"/>
                </VBox>

                <!-- Orders Card -->
                <VBox alignment="CENTER" spacing="14" prefWidth="220"
                      style="-fx-background-color: #16213e; -fx-background-radius: 12;
                             -fx-border-color: #1e3a5f; -fx-border-radius: 12; -fx-padding: 32;">
                    <Label text="📦" style="-fx-font-size: 40px;"/>
                    <Label text="Orders" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #e2e8f0;"/>
                    <Label text="Manage customer orders" style="-fx-font-size: 12px; -fx-text-fill: #64748b;" wrapText="true"/>
                    <Button text="Open Orders" onAction="#goToOrders" maxWidth="Infinity"
                            style="-fx-background-color: #7c3aed; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-background-radius: 8;
                                   -fx-padding: 10 0; -fx-cursor: hand;"/>
                </VBox>

                <!-- Products Card -->
                <VBox alignment="CENTER" spacing="14" prefWidth="220"
                      style="-fx-background-color: #16213e; -fx-background-radius: 12;
                             -fx-border-color: #1e3a5f; -fx-border-radius: 12; -fx-padding: 32;">
                    <Label text="🛒" style="-fx-font-size: 40px;"/>
                    <Label text="Products" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #e2e8f0;"/>
                    <Label text="Manage product catalog" style="-fx-font-size: 12px; -fx-text-fill: #64748b;" wrapText="true"/>
                    <Button text="Open Products" onAction="#goToProducts" maxWidth="Infinity"
                            style="-fx-background-color: #059669; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-background-radius: 8;
                                   -fx-padding: 10 0; -fx-cursor: hand;"/>
                </VBox>

            </HBox>
        </VBox>
    </center>
</BorderPane>

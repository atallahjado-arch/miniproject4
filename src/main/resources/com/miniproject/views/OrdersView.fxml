<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.miniproject.controller.OrdersController"
            style="-fx-background-color: #1a1a2e;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="14"
              style="-fx-background-color: #16213e; -fx-padding: 14 24;">
            <Button text="← Back" onAction="#goBack"
                    style="-fx-background-color: transparent; -fx-text-fill: #94a3b8;
                           -fx-border-color: #334155; -fx-border-radius: 6;
                           -fx-background-radius: 6; -fx-padding: 6 14; -fx-cursor: hand;"/>
            <Label text="Orders Management"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #e2e8f0;"/>
        </HBox>
    </top>

    <center>
        <HBox spacing="0">

            <VBox HBox.hgrow="ALWAYS" style="-fx-padding: 20;">
                <TableView fx:id="tableView" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: #16213e; -fx-border-color: #1e3a5f; -fx-border-radius: 8;">
                    <columns>
                        <TableColumn fx:id="colId"      text="ID"       prefWidth="50"/>
                        <TableColumn fx:id="colClient"  text="Client"   prefWidth="130"/>
                        <TableColumn fx:id="colProduct" text="Product"  prefWidth="130"/>
                        <TableColumn fx:id="colQty"     text="Qty"      prefWidth="60"/>
                        <TableColumn fx:id="colTotal"   text="Total $"  prefWidth="90"/>
                        <TableColumn fx:id="colStatus"  text="Status"   prefWidth="100"/>
                    </columns>
                    <placeholder><Label text="No orders yet." style="-fx-text-fill: #64748b;"/></placeholder>
                </TableView>
            </VBox>

            <VBox spacing="14" prefWidth="300"
                  style="-fx-background-color: #16213e; -fx-padding: 24;
                         -fx-border-color: #1e3a5f; -fx-border-width: 0 0 0 1;">
                <Label text="Order Details"
                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #e2e8f0;"/>

                <VBox spacing="5">
                    <Label text="Client Name *" style="-fx-text-fill: #94a3b8; -fx-font-size: 12px;"/>
                    <TextField fx:id="clientNameField" promptText="Client name"
                               style="-fx-background-color: #0f3460; -fx-text-fill: #e2e8f0;
                                      -fx-prompt-text-fill: #475569; -fx-background-radius: 6;
                                      -fx-border-color: #334155; -fx-border-radius: 6; -fx-padding: 8 10;"/>
                </VBox>
                <VBox spacing="5">
                    <Label text="Product *" style="-fx-text-fill: #94a3b8; -fx-font-size: 12px;"/>
                    <TextField fx:id="productField" promptText="Product name"
                               style="-fx-background-color: #0f3460; -fx-text-fill: #e2e8f0;
                                      -fx-prompt-text-fill: #475569; -fx-background-radius: 6;
                                      -fx-border-color: #334155; -fx-border-radius: 6; -fx-padding: 8 10;"/>
                </VBox>
                <VBox spacing="5">
                    <Label text="Quantity *" style="-fx-text-fill: #94a3b8; -fx-font-size: 12px;"/>
                    <TextField fx:id="quantityField" promptText="e.g. 3"
                               style="-fx-background-color: #0f3460; -fx-text-fill: #e2e8f0;
                                      -fx-prompt-text-fill: #475569; -fx-background-radius: 6;
                                      -fx-border-color: #334155; -fx-border-radius: 6; -fx-padding: 8 10;"/>
                </VBox>
                <VBox spacing="5">
                    <Label text="Total Price ($) *" style="-fx-text-fill: #94a3b8; -fx-font-size: 12px;"/>
                    <TextField fx:id="totalPriceField" promptText="e.g. 299.99"
                               style="-fx-background-color: #0f3460; -fx-text-fill: #e2e8f0;
                                      -fx-prompt-text-fill: #475569; -fx-background-radius: 6;
                                      -fx-border-color: #334155; -fx-border-radius: 6; -fx-padding: 8 10;"/>
                </VBox>
                <VBox spacing="5">
                    <Label text="Status" style="-fx-text-fill: #94a3b8; -fx-font-size: 12px;"/>
                    <ComboBox fx:id="statusCombo" maxWidth="Infinity"
                              style="-fx-background-color: #0f3460; -fx-border-color: #334155;
                                     -fx-border-radius: 6; -fx-background-radius: 6;"/>
                </VBox>

                <Label fx:id="statusLabel" text="" wrapText="true"
                       style="-fx-text-fill: #4ade80; -fx-font-size: 12px;"/>

                <Region VBox.vgrow="ALWAYS"/>

                <Button text="Add Order" onAction="#handleAdd" maxWidth="Infinity"
                        style="-fx-background-color: #7c3aed; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-background-radius: 6;
                               -fx-padding: 10 0; -fx-cursor: hand;"/>
                <Button text="Update Selected" onAction="#handleUpdate" maxWidth="Infinity"
                        style="-fx-background-color: #4361ee; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-background-radius: 6;
                               -fx-padding: 10 0; -fx-cursor: hand;"/>
                <Button text="Delete Selected" onAction="#handleDelete" maxWidth="Infinity"
                        style="-fx-background-color: #dc2626; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-background-radius: 6;
                               -fx-padding: 10 0; -fx-cursor: hand;"/>
                <Button text="Clear Form" onAction="#handleClear" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8;
                               -fx-border-color: #334155; -fx-border-radius: 6;
                               -fx-background-radius: 6; -fx-padding: 8 0; -fx-cursor: hand;"/>
            </VBox>
        </HBox>
    </center>
</BorderPane>

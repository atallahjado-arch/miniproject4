<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.miniproject.controller.ProductsController"
            style="-fx-background-color: #1a1a2e;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="14"
              style="-fx-background-color: #16213e; -fx-padding: 14 24;">
            <Button text="← Back" onAction="#goBack"
                    style="-fx-background-color: transparent; -fx-text-fill: #94a3b8;
                           -fx-border-color: #334155; -fx-border-radius: 6;
                           -fx-background-radius: 6; -fx-padding: 6 14; -fx-cursor: hand;"/>
            <Label text="Products Management"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #e2e8f0;"/>
        </HBox>
    </top>

    <center>
        <HBox spacing="0">

            <VBox HBox.hgrow="ALWAYS" style="-fx-padding: 20;">
                <TableView fx:id="tableView" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: #16213e; -fx-border-color: #1e3a5f; -fx-border-radius: 8;">
                    <columns>
                        <TableColumn fx:id="colId"          text="ID"          prefWidth="50"/>
                        <TableColumn fx:id="colName"        text="Name"        prefWidth="150"/>
                        <TableColumn fx:id="colCategory"    text="Category"    prefWidth="110"/>
                        <TableColumn fx:id="colPrice"       text="Price ($)"   prefWidth="90"/>
                        <TableColumn fx:id="colStock"       text="Stock"       prefWidth="70"/>
                        <TableColumn fx:id="colDescription" text="Description" prefWidth="200"/>
                    </columns>
                    <placeholder><Label text="No products yet." style="-fx-text-fill: #64748b;"/></placeholder>
                </TableView>
            </VBox>

            <VBox spacing="14" prefWidth="300"
                  style="-fx-background-color: #16213e; -fx-padding: 24;
                         -fx-border-color: #1e3a5f; -fx-border-width: 0 0 0 1;">
                <Label text="Product Details"
                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #e2e8f0;"/>

                <VBox spacing="5">
                    <Label text="Name *" style="-fx-text-fill: #94a3b8; -fx-font-size: 12px;"/>
                    <TextField fx:id="nameField" promptText="Product name"
                               style="-fx-background-color: #0f3460; -fx-text-fill: #e2e8f0;
                                      -fx-prompt-text-fill: #475569; -fx-background-radius: 6;
                                      -fx-border-color: #334155; -fx-border-radius: 6; -fx-padding: 8 10;"/>
                </VBox>
                <VBox spacing="5">
                    <Label text="Category" style="-fx-text-fill: #94a3b8; -fx-font-size: 12px;"/>
                    <TextField fx:id="categoryField" promptText="e.g. Electronics"
                               style="-fx-background-color: #0f3460; -fx-text-fill: #e2e8f0;
                                      -fx-prompt-text-fill: #475569; -fx-background-radius: 6;
                                      -fx-border-color: #334155; -fx-border-radius: 6; -fx-padding: 8 10;"/>
                </VBox>
                <VBox spacing="5">
                    <Label text="Price ($) *" style="-fx-text-fill: #94a3b8; -fx-font-size: 12px;"/>
                    <TextField fx:id="priceField" promptText="e.g. 99.99"
                               style="-fx-background-color: #0f3460; -fx-text-fill: #e2e8f0;
                                      -fx-prompt-text-fill: #475569; -fx-background-radius: 6;
                                      -fx-border-color: #334155; -fx-border-radius: 6; -fx-padding: 8 10;"/>
                </VBox>
                <VBox spacing="5">
                    <Label text="Stock *" style="-fx-text-fill: #94a3b8; -fx-font-size: 12px;"/>
                    <TextField fx:id="stockField" promptText="e.g. 50"
                               style="-fx-background-color: #0f3460; -fx-text-fill: #e2e8f0;
                                      -fx-prompt-text-fill: #475569; -fx-background-radius: 6;
                                      -fx-border-color: #334155; -fx-border-radius: 6; -fx-padding: 8 10;"/>
                </VBox>
                <VBox spacing="5">
                    <Label text="Description" style="-fx-text-fill: #94a3b8; -fx-font-size: 12px;"/>
                    <TextField fx:id="descriptionField" promptText="Short description"
                               style="-fx-background-color: #0f3460; -fx-text-fill: #e2e8f0;
                                      -fx-prompt-text-fill: #475569; -fx-background-radius: 6;
                                      -fx-border-color: #334155; -fx-border-radius: 6; -fx-padding: 8 10;"/>
                </VBox>

                <Label fx:id="statusLabel" text="" wrapText="true"
                       style="-fx-text-fill: #4ade80; -fx-font-size: 12px;"/>

                <Region VBox.vgrow="ALWAYS"/>

                <Button text="Add Product" onAction="#handleAdd" maxWidth="Infinity"
                        style="-fx-background-color: #059669; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-background-radius: 6;
                               -fx-padding: 10 0; -fx-cursor: hand;"/>
                <Button text="Update Selected" onAction="#handleUpdate" maxWidth="Infinity"
                        style="-fx-background-color: #4361ee; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-background-radius: 6;
                               -fx-padding: 10 0; -fx-cursor: hand;"/>
                <Button text="Delete Selected" onAction="#handleDelete" maxWidth="Infinity"
                        style="-fx-background-color: #dc2626; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-background-radius: 6;
                               -fx-padding: 10 0; -fx-cursor: hand;"/>
                <Button text="Clear Form" onAction="#handleClear" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8;
                               -fx-border-color: #334155; -fx-border-radius: 6;
                               -fx-background-radius: 6; -fx-padding: 8 0; -fx-cursor: hand;"/>
            </VBox>
        </HBox>
    </center>
</BorderPane>
